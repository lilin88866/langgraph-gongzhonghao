CONTENT_API_REQUIRE_REAL=1
WECHAT_PROVIDER=wechat_download
WECHAT_DOWNLOAD_API_BASE_URL=http://localhost:5000
WECHAT_DOWNLOAD_API_AUTO_START=1
WECHAT_ARTICLE_DETAIL_TIMEOUT_SECONDS=90

# Optional: comma-separated fakeids. If omitted, SEARCH_QUERY first calls
# /api/public/searchbiz and then searches the discovered accounts.
WECHAT_DOWNLOAD_DEFAULT_FAKEIDS=

# Discover AI-related WeChat Official Accounts. Keep auto-subscribe off unless you explicitly approve it.
WECHAT_ACCOUNT_AUTO_SUBSCRIBE=0
WECHAT_ACCOUNT_DISCOVERY_LIMIT=20
WECHAT_ACCOUNT_DISCOVERY_KEYWORDS=AI,AIGC,Agent,智能体,人工智能,Claude,Claude Code,ChatGPT,OpenAI,DeepSeek,Gemini,Qwen,通义千问,大模型,生成式AI,AI工具,AI产品,AI应用,AI编程,AI自动化,提示词,Prompt,promot,LangGraph,LangChain,langchain,loop,RAG,MCP
WECHAT_ACCOUNT_MATCH_KEYWORDS=AI,AIGC,Agent,智能体,人工智能,Claude,Claude Code,ChatGPT,OpenAI,DeepSeek,Gemini,Qwen,通义千问,大模型,生成式AI,AI工具,AI产品,AI应用,AI编程,AI自动化,提示词,Prompt,promot,LangGraph,LangChain,langchain,loop,RAG,MCP
WECHAT_COLLECTION_DISCOVERED_ACCOUNT_LIMIT=50
WECHAT_COLLECTION_INCLUDE_SEARCH_PLANS=0
WECHAT_HOTNESS_ONLY_YESTERDAY=1
WECHAT_HOTNESS_TIMEZONE_OFFSET_HOURS=8
# Optional override. Leave unset to use the project-local skills/wechat-rewrite directory.
# WECHAT_REWRITE_SKILL_DIR=skills/wechat-rewrite

# Optional: read Xiaohongshu notes from a ForgeRSS-generated RSS feed.
XIAOHONGSHU_PROVIDER=forgerss
XIAOHONGSHU_FORGERSS_FEED_FILE=external/ForgeRSS/feeds/feed_xiaohongshu_user.xml
# XIAOHONGSHU_FORGERSS_FEED_URL=http://localhost:8001/feeds/feed_xiaohongshu_user.xml

# Optional: execute wechat-rewrite prompts with an OpenAI-compatible model.
# Cloud-first option: use DashScope first, then fall back to local Ollama only on quota/balance errors.
QWEN_API_KEY=your_dashscope_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus
QWEN_TIMEOUT_SECONDS=300
QWEN_REWRITE_PREFER_LOCAL=0
QWEN_FALLBACK_API_KEY=ollama
QWEN_FALLBACK_BASE_URL=http://localhost:11434/v1
QWEN_FALLBACK_MODEL=qwen2.5:7b
QWEN_FALLBACK_TIMEOUT_SECONDS=300
QWEN_FALLBACK_AUTO_START=1
QWEN_FALLBACK_AUTO_PULL=1
DASHSCOPE_IMAGE_MODEL=wan2.2-t2i-flash
DASHSCOPE_IMAGE_EDIT_MODEL=wan2.7-image

# Automatically refresh subscribed WeChat accounts through wechat-download-api.
WECHAT_AUTO_REFRESH=1
WECHAT_REFRESH_INTERVAL_SECONDS=14400
WECHAT_REFRESH_HISTORY_COUNT=20
WECHAT_REFRESH_REQUEST_TIMEOUT_SECONDS=300
WECHAT_REFRESH_BATCH_SIZE=2
WECHAT_REFRESH_USE_RSS_POLL=0
